{
  "name": "smart-school-erp-backend",
  "version": "1.0.0",
  "description": "शहीद राम सिंह विद्यालय — Smart School ERP Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "ts-node src/database/migrate.ts",
    "migrate:seed": "ts-node src/database/migrate.ts --seed",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "express": "^4.18.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "pg": "^8.11.3",
    "pg-pool": "^3.6.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.1",
    "nodemailer": "^6.9.10",
    "twilio": "^4.23.0",
    "firebase-admin": "^12.0.0",
    "aws-sdk": "^2.1550.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "pdfkit": "^0.14.0",
    "exceljs": "^4.4.0",
    "joi": "^17.12.2",
    "dayjs": "^1.11.10",
    "zod": "^3.22.4",
    "dotenv": "^16.4.5",
    "cookie-parser": "^1.4.6",
    "express-async-errors": "^3.1.1",
    "hpp": "^0.2.3",
    "xss-clean": "^0.1.4",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/compression": "^1.7.5",
    "@types/pg": "^8.11.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^9.0.8",
    "@types/nodemailer": "^6.4.14",
    "@types/multer": "^1.4.11",
    "@types/cookie-parser": "^1.4.7",
    "@types/node": "^20.11.25",
    "@types/pdfkit": "^0.13.4",
    "typescript": "^5.4.2",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.12",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "prettier": "^3.2.5"
  }
}
